# P007麒麟项目环境配置模板
# 复制此文件为 .env 并填写实际值

# ================= 环境设置 =================
NODE_ENV=${NODE_ENV:-development}

# ================= 服务器配置 =================
PORT=${API_PORT:-33037}
HOST=${API_HOST:-0.0.0.0}

# ================= 数据库配置 =================
DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/qilin_dev}

# ================= 日志配置 =================
LOG_LEVEL=${LOG_LEVEL:-debug}

# ================= CORS配置 =================
CORS_ORIGIN=${FRONTEND_URL:-http://${FRONTEND_HOST:-localhost}:${FRONTEND_PORT:-5177}}

# ================= API配置 =================
API_BASE_URL=${API_BASE_URL:-http://${API_HOST:-localhost}:${API_PORT:-33037}}
API_PREFIX=${API_PREFIX:-/api}
API_VERSION=${API_VERSION:-v1}

# ================= 前端配置 =================
FRONTEND_URL=${FRONTEND_URL:-http://${FRONTEND_HOST:-localhost}:${FRONTEND_PORT:-5177}}
FRONTEND_PORT=${FRONTEND_PORT:-5177}

# ================= 认证配置 =================
JWT_SECRET=${JWT_SECRET:-your-jwt-secret-key-minimum-32-characters}
JWT_EXPIRES_IN=${JWT_EXPIRES_IN:-7d}
JWT_REFRESH_EXPIRES_IN=${JWT_REFRESH_EXPIRES_IN:-30d}

# ================= 业务配置 =================
DEFAULT_CURRENCY=${DEFAULT_CURRENCY:-CNY}
DEFAULT_LANGUAGE=${DEFAULT_LANGUAGE:-zh-CN}
DEFAULT_TIMEZONE=${DEFAULT_TIMEZONE:-Asia/Shanghai}

# ================= 云打印配置 =================
SHANGPENG_APP_ID=${SHANGPENG_APP_ID:-your-shangpeng-app-id}
SHANGPENG_APP_SECRET=${SHANGPENG_APP_SECRET:-your-shangpeng-app-secret}
SHANGPENG_BASE_URL=${SHANGPENG_BASE_URL:-https://open.spyun.net/v1/}
