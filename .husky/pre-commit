#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 提交前检查..."

# 硬编码检查（简化版，不依赖环境变量）
cd apps/backend && npm run check:hardcoded 2>&1 || {
  echo "❌ 硬编码检查失败"
  echo "   请运行 npm run check:hardcoded 查看详情"
  exit 1
}
echo "✅ 硬编码检查通过"

cd ../frontend

# 前端语法检查（括号匹配、引号等）
bash ../../scripts/check-syntax.sh 2>&1 || {
    echo "❌ 前端语法检查失败"
    exit 1
}

echo "🎉 提交前检查通过！"
