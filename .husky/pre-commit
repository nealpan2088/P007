#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 运行提交前检查..."

# 使用静默检查模式
echo "📋 运行静默检查..."

# 检查后端
cd apps/backend
if [ -f scripts/check-silent.sh ]; then
    ./scripts/check-silent.sh
    if [ $? -ne 0 ]; then
        echo "❌ 后端检查失败，请运行详细检查:"
        echo "  npm run check:all"
        exit 1
    fi
    echo "✅ 后端检查通过"
else
    # 回退到详细检查
    echo "⚠️  静默检查脚本不存在，使用详细检查"
    npm run check:all
    if [ $? -ne 0 ]; then
        exit 1
    fi
fi

# 检查前端
cd ../frontend
npm run check:all > /dev/null 2>&1
if [ $? -ne 0 ]; then
    echo "❌ 前端检查失败，请运行详细检查:"
    echo "  npm run check:all"
    exit 1
fi
echo "✅ 前端检查通过"

# 运行ESLint
echo "📋 运行代码检查..."
cd ../backend && npm run lint
BACKEND_LINT_RESULT=$?

cd ../frontend && npm run lint
FRONTEND_LINT_RESULT=$?

if [ $BACKEND_LINT_RESULT -ne 0 ] || [ $FRONTEND_LINT_RESULT -ne 0 ]; then
    echo "❌ 代码检查失败，请修复后再提交"
    exit 1
fi

echo "✅ 代码检查通过"

echo "🎉 所有检查通过，可以提交！"