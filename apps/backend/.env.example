# 麒麟项目后端 - 环境配置模板
# 复制此文件为 .env 并填写实际值

# 环境设置
NODE_ENV=development
PORT=33038

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qilin_dev

# 安全配置
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# API配置
API_PREFIX=/api

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# CORS配置
CORS_ORIGIN=http://localhost:5177
CORS_CREDENTIALS=true

# 速率限制
RATE_LIMIT_WINDOW_MS=900000  # 15分钟
RATE_LIMIT_MAX_REQUESTS=100  # 每个IP每15分钟最多100个请求

# 上传配置
MAX_FILE_SIZE=5242880  # 5MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# 打印机配置 (扫码点餐)
# 商鹏云打印机配置
SHANGPENG_APP_ID=your-shangpeng-app-id
SHANGPENG_APP_SECRET=your-shangpeng-app-secret
SHANGPENG_PRINTER_SN=your-printer-serial-number

# 飞鹅云打印机配置 (可选)
FEIE_USER=your-feie-user
FEIE_UKEY=your-feie-ukey
FEIE_PRINTER_SN=your-feie-printer-sn

# 开发工具
ENABLE_SWAGGER=true
ENABLE_GRAPHQL_PLAYGROUND=false

# 功能开关
FEATURE_SCAN_ORDER=true
FEATURE_PRINT_ORDER=true
FEATURE_MULTI_TENANT=true

# 邮件配置 (可选)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password