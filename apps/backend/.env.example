# ============================================
# 麒麟项目 - 环境变量配置
# 所有配置通过环境变量管理，禁止硬编码
# ============================================

# ================= 服务器配置 =================
NODE_ENV=development
PORT=33037
HOST=0.0.0.0
API_PREFIX=/api
API_VERSION=v1

# CORS配置
CORS_ORIGIN=http://localhost:5177,http://localhost:5178
CORS_CREDENTIALS=true

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# ================= 数据库配置 =================
DATABASE_URL="postgresql://username:password@localhost:5432/p007_db"

# ================= 系统模式配置 =================
# 系统模式：single (单店版) | multi (多店版/SaaS)
SYSTEM_MODE=multi

# 单店版配置（当 SYSTEM_MODE=single 时生效）
DEFAULT_STORE_ID=store_001
DEFAULT_STORE_NAME="默认店铺"
DEFAULT_STORE_SUBDOMAIN=default
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_PUBLIC_SCHEMA=p007_public
DB_TENANT_SCHEMA_PREFIX=tenant_

# 连接池配置
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE_TIMEOUT=30000
DB_POOL_IDLE_TIMEOUT=10000

# ================= 认证配置 =================
JWT_SECRET="your-super-secure-jwt-secret-key-minimum-32-characters"
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 密码策略
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# 会话配置
SESSION_COOKIE_NAME=qilin_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=strict
SESSION_MAX_AGE=86400000

# ================= 租户配置 =================
SUBDOMAIN_REGEX="^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$"
RESERVED_SUBDOMAINS=www,app,api,admin,test,demo

# 免费计划
PLAN_FREE_MAX_STORES=1
PLAN_FREE_MAX_USERS=3
PLAN_FREE_MAX_PRINTERS=1
PLAN_FREE_FEATURES=basic_ordering,basic_reporting

# 基础计划
PLAN_BASIC_MAX_STORES=3
PLAN_BASIC_MAX_USERS=10
PLAN_BASIC_MAX_PRINTERS=3
PLAN_BASIC_FEATURES=basic_ordering,advanced_reporting,api_access

# 高级计划
PLAN_PREMIUM_MAX_STORES=10
PLAN_PREMIUM_MAX_USERS=50
PLAN_PREMIUM_MAX_PRINTERS=10
PLAN_PREMIUM_FEATURES=all_features,custom_integrations,priority_support

# 试用和计费
TRIAL_DAYS=14
BILLING_CYCLE_MONTHLY_PRICE=299
BILLING_CYCLE_YEARLY_PRICE=2999

# ================= 业务配置 =================
# 店铺默认设置
DEFAULT_TAX_RATE=0.06
DEFAULT_SERVICE_CHARGE=0.10
DEFAULT_CURRENCY=CNY
DEFAULT_LANGUAGE=zh-CN
DEFAULT_TIMEZONE=Asia/Shanghai

# 订单配置
ORDER_NUMBER_PREFIX=ORD
ORDER_NUMBER_LENGTH=8
ORDER_AUTO_CANCEL_MINUTES=30

# 打印配置
PRINT_RETRY_ATTEMPTS=3
PRINT_RETRY_DELAY=5000
PRINT_TIMEOUT=30000

# 商鹏云打印配置
SHANGPENG_APP_ID=your_shangpeng_app_id
SHANGPENG_APP_SECRET=your_shangpeng_app_secret
SHANGPENG_BASE_URL=https://open.spyun.net/v1/
SHANGPENG_TIMEOUT=10000

# ================= 安全配置 =================
# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_FAILED=true

# 请求限制 (单位字节，Fastify需要整数)
BODY_LIMIT=1048576 # 1MB

# 安全头
HSTS_MAX_AGE=31536000
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION="1; mode=block"
REFERRER_POLICY=strict-origin-when-cross-origin
CONTENT_SECURITY_POLICY="default-src 'self'"

# 审计日志
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info

# ================= 监控配置 =================
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
METRICS_PORT=9090

# 告警配置
ALERT_WEBHOOK_URL=
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=80
ALERT_RESPONSE_TIME_THRESHOLD=1000
ALERT_ERROR_RATE_THRESHOLD=5

# ============================================
# 重要提醒：
# 1. 生产环境必须设置强密码和密钥
# 2. 敏感信息必须通过安全方式管理
# 3. 定期轮换密钥和密码
# ============================================
