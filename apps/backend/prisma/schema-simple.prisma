// 麒麟项目 - 数据库Schema (简化版)
// 只包含公共Schema表，租户表在运行时动态创建

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 公共Schema (p007_public) ====================
// 公共表，存储平台级数据，所有租户共享

// 用户表 - 平台用户
model User {
  // 基础信息
  id                String    @id @default(cuid())
  email             String    @unique @db.VarChar(255)
  username          String?   @db.VarChar(100)
  fullName          String?   @db.VarChar(200)
  phone             String?   @db.VarChar(20)
  avatar            String?   @db.VarChar(500)
  
  // 认证信息
  passwordHash      String    @db.VarChar(255)
  passwordSalt      String    @db.VarChar(255)
  emailVerified     Boolean   @default(false)
  verificationToken String?   @db.VarChar(255)
  verificationTokenExpiresAt DateTime?
  resetPasswordToken String?  @db.VarChar(255)
  resetPasswordTokenExpiresAt DateTime?
  
  // 状态
  status            UserStatus @default(ACTIVE)
  lastLoginAt       DateTime?
  failedLoginAttempts Int      @default(0)
  lockedUntil       DateTime?
  
  // 时间戳
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  
  // 关系
  tenants           UserTenant[]
  sessions          Session[]
  
  // 索引
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// 用户状态枚举
enum UserStatus {
  ACTIVE      // 活跃
  INACTIVE    // 未激活
  SUSPENDED   // 已暂停
  DELETED     // 已删除
}

// 租户表 - SaaS租户（餐厅/店铺）
model Tenant {
  // 基础信息
  id              String    @id @default(cuid())
  name            String    @db.VarChar(200)
  subdomain       String    @unique @db.VarChar(100)
  displayName     String    @db.VarChar(200)
  description     String?   @db.Text
  logo            String?   @db.VarChar(500)
  website         String?   @db.VarChar(500)
  
  // 联系信息
  contactEmail    String    @db.VarChar(255)
  contactPhone    String?   @db.VarChar(20)
  contactPerson   String?   @db.VarChar(100)
  address         String?   @db.Text
  
  // 业务信息
  businessType    String?   @db.VarChar(100)
  industry        String?   @db.VarChar(100)
  employeeCount   Int?
  establishedYear Int?
  
  // 套餐和计费
  plan            TenantPlan @default(FREE)
  planStartedAt   DateTime  @default(now())
  planExpiresAt   DateTime?
  billingCycle    BillingCycle @default(MONTHLY)
  stripeCustomerId String?  @db.VarChar(255)
  stripeSubscriptionId String? @db.VarChar(255)
  
  // 试用期
  trialStartedAt  DateTime?
  trialEndsAt     DateTime?
  trialConverted  Boolean   @default(false)
  
  // 状态
  status          TenantStatus @default(ACTIVE)
  verified        Boolean   @default(false)
  verificationNotes String? @db.Text
  
  // 配置
  settings        Json      @default("{}")
  features        Json      @default("{}")
  
  // 时间戳
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  
  // 关系
  users           UserTenant[]
  
  // 索引
  @@index([subdomain])
  @@index([plan])
  @@index([status])
  @@index([createdAt])
}

// 租户套餐枚举
enum TenantPlan {
  FREE     // 免费版
  BASIC    // 基础版
  PREMIUM  // 高级版
  ENTERPRISE // 企业版
}

// 租户状态枚举
enum TenantStatus {
  ACTIVE      // 活跃
  TRIAL       // 试用中
  SUSPENDED   // 已暂停
  CANCELLED   // 已取消
  DELETED     // 已删除
}

// 计费周期枚举
enum BillingCycle {
  MONTHLY   // 月付
  YEARLY    // 年付
}

// 用户-租户关联表 (多对多)
model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      UserRole @default(USER)
  
  // 权限
  permissions Json   @default("[]")
  
  // 状态
  status    UserTenantStatus @default(ACTIVE)
  invitedAt DateTime?
  joinedAt  DateTime @default(now())
  removedAt DateTime?
  
  // 时间戳
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // 关系
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // 唯一约束
  @@unique([userId, tenantId])
  
  // 索引
  @@index([userId])
  @@index([tenantId])
  @@index([role])
  @@index([status])
}

// 用户角色枚举
enum UserRole {
  SUPER_ADMIN  // 超级管理员 (平台级)
  ADMIN        // 管理员 (租户级)
  MANAGER      // 经理
  STAFF        // 员工
  USER         // 普通用户
  VIEWER       // 查看者
}

// 用户-租户状态枚举
enum UserTenantStatus {
  PENDING   // 邀请待接受
  ACTIVE    // 活跃
  INACTIVE  // 未激活
  SUSPENDED // 已暂停
  REMOVED   // 已移除
}

// 会话表 - 用户登录会话
model Session {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String?
  
  // 会话信息
  token        String   @unique @db.VarChar(500)
  refreshToken String?  @db.VarChar(500)
  userAgent    String?  @db.Text
  ipAddress    String?  @db.VarChar(45)
  deviceType   String?  @db.VarChar(50)
  deviceId     String?  @db.VarChar(255)
  
  // 有效期
  expiresAt    DateTime
  refreshTokenExpiresAt DateTime?
  
  // 状态
  revoked      Boolean  @default(false)
  revokedAt    DateTime?
  revokedReason String? @db.VarChar(255)
  
  // 时间戳
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // 关系
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  
  // 索引
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([createdAt])
}