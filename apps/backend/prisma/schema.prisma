generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String       @id @default(cuid())
  email                       String       @unique
  username                    String?
  fullName                    String?
  phone                       String?
  avatar                      String?
  passwordHash                String
  passwordSalt                String
  emailVerified               Boolean      @default(false)
  verificationToken           String?
  verificationTokenExpiresAt  DateTime?
  resetPasswordToken          String?
  resetPasswordTokenExpiresAt DateTime?
  status                      String       @default("ACTIVE")
  lastLoginAt                 DateTime?
  failedLoginAttempts         Int          @default(0)
  lockedUntil                 DateTime?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
  deletedAt                   DateTime?
  sessions                    Session[]
  tenants                     UserTenant[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Tenant {
  id                   String       @id @default(cuid())
  name                 String
  subdomain            String       @unique
  displayName          String
  description          String?
  logo                 String?
  website              String?
  contactEmail         String
  contactPhone         String?
  contactPerson        String?
  address              String?
  businessType         String?
  industry             String?
  employeeCount        Int?
  establishedYear      Int?
  plan                 String       @default("FREE")
  planStartedAt        DateTime     @default(now())
  planExpiresAt        DateTime?
  billingCycle         String       @default("MONTHLY")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialStartedAt       DateTime?
  trialEndsAt          DateTime?
  trialConverted       Boolean      @default(false)
  status               String       @default("ACTIVE")
  verified             Boolean      @default(false)
  verificationNotes    String?
  settings             Json         @default("{}")
  features             Json         @default("{}")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?
  sessions             Session[]
  users                UserTenant[]

  @@index([subdomain])
  @@index([plan])
  @@index([status])
  @@index([createdAt])
}

model UserTenant {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String
  role        String    @default("USER")
  permissions Json      @default("[]")
  status      String    @default("ACTIVE")
  invitedAt   DateTime?
  joinedAt    DateTime  @default(now())
  removedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([role])
  @@index([status])
}

model Session {
  id                    String    @id @default(cuid())
  userId                String
  tenantId              String?
  token                 String    @unique
  refreshToken          String?
  userAgent             String?
  ipAddress             String?
  deviceType            String?
  deviceId              String?
  expiresAt             DateTime
  refreshTokenExpiresAt DateTime?
  revoked               Boolean   @default(false)
  revokedAt             DateTime?
  revokedReason         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  tenant                Tenant?   @relation(fields: [tenantId], references: [id])
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([createdAt])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum TenantPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  DELETED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  USER
}

enum UserTenantStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  REMOVED
}
