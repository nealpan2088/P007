generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 核心模型 - 新麒麟项目设计
// ============================================

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  username                  String?
  fullName                  String?
  phone                     String?
  passwordHash              String
  passwordSalt              String?
  role                      String    @default("USER")
  status                    String    @default("ACTIVE")
  verificationToken         String?
  verificationTokenExpiresAt DateTime?
  failedLoginAttempts       Int       @default(0)
  lockedUntil               DateTime?
  lastLoginAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  deletedAt                 DateTime?

  sessions                  Session[]
  userTenants               UserTenant[]
  storeAssignments          UserStore[]
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  subdomain   String   @unique
  description String?
  plan        String   @default("FREE")
  contactEmail String?
  trialEndsAt DateTime?
  status      String   @default("ACTIVE")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  sessions    Session[]
  userTenants UserTenant[]
  stores      Store[]
}

model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String   @default("USER")
  status    String   @default("ACTIVE")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model Session {
  id                    String   @id @default(cuid())
  userId                String
  tenantId              String?
  token                 String   @unique
  expiresAt             DateTime
  revoked               Boolean  @default(false)
  revokedReason         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant?  @relation(fields: [tenantId], references: [id])
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ============================================
// 店铺管理模型
// ============================================

enum StoreStatus {
  DRAFT
  ACTIVE
  INACTIVE
  MAINTENANCE
  DELETED
}

enum StoreType {
  RESTAURANT
  CAFE
  FAST_FOOD
  BAKERY
  BAR
  FOOD_TRUCK
  CATERING
  OTHER
}

model Store {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  slug             String   @unique
  description      String?
  type             StoreType   @default(RESTAURANT)
  status           StoreStatus @default(DRAFT)

  // 联系信息
  contactPhone     String?
  contactEmail     String?
  address          String?

  // 配置
  timezone         String?  @default("Asia/Shanghai")
  currency         String?  @default("CNY")
  language         String?  @default("zh-CN")
  logoUrl          String?
  headerImageUrl   String?
  themeColor       String?  @default("#ff6b35")
  themeTemplate    String?  @default("minimal")

  // 业务设置
  tableCount       Int?     @default(20)
  printerEnabled   Boolean  @default(false)
  qrCodeEnabled    Boolean  @default(true)

  // 时间戳
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  // 关系
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables           Table[]
  menuCategories   MenuCategory[]
  printers         Printer[]
  orders           Order[]
  storeAssignments UserStore[]
  flowOverrides    StoreFlowOverride[]

  @@index([tenantId])
  @@index([slug])
  @@index([status])
}

// 用户-店铺关联（店长、店员等店铺级角色）
model UserStore {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  role      String   @default("STORE_ADMIN") // 预留扩展：STORE_ADMIN, STORE_STAFF 等
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([userId])
  @@index([storeId])
}

model Table {
  id          String   @id @default(cuid())
  storeId     String
  tableNumber String
  name        String?
  capacity    Int      @default(4)
  status      String   @default("AVAILABLE")
  qrCodeUrl   String?
  shortCode   String?  @unique
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([storeId, tableNumber])
  @@index([storeId])
  @@index([tableNumber])
  @@index([shortCode])
}

// ============================================
// 菜单管理模型
// ============================================

model MenuCategory {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items       MenuItem[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([sortOrder])
}

model MenuItem {
  id              String   @id @default(cuid())
  categoryId      String
  name            String
  description     String?
  price           Float
  imageUrl        String?
  isAvailable     Boolean  @default(true)
  isRecommended   Boolean  @default(false)
  preparationTime Int?     @default(15)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  // 模板来源标记（可选，仅平台级素材库中有值）
  templateId      String?

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([isAvailable])
  @@index([isRecommended])
  @@index([templateId])
}

// 平台级菜品模板（管理员维护的公共素材库）
model MenuTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  categoryName    String   // 对应分类名称（素材库中的分类名）
  price           Float
  imageUrl        String?  // 图片URL或上传路径
  tags            String?  // JSON数组：["推荐","辣","新品"]
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String   // 创建人

  @@index([categoryName])
  @@index([name])
  @@index([isActive])
  @@index([sortOrder])
}

// ============================================
// 订单管理模型
// ============================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id                 String       @id @default(cuid())
  storeId            String
  tableId            String?
  orderNumber        String       @unique
  customerName       String?
  customerPhone      String?
  customerNotes      String?
  orderType          String       @default("DINE_IN")
  status             OrderStatus  @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING)
  subtotal           Float
  totalAmount        Float
  paymentMethod      String?
  estimatedReadyAt   DateTime?
  readyAt            DateTime?
  servedAt           DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  store              Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table              Table?       @relation(fields: [tableId], references: [id])
  items              OrderItem[]

  @@index([storeId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  menuItemId          String
  quantity            Int      @default(1)
  unitPrice           Float
  totalPrice          Float
  specialInstructions String?
  status              String   @default("PENDING")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem            MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
}

// ============================================
// 云打印机模型
// ============================================

enum PrinterStatus {
  ACTIVE
  INACTIVE
  FAULT
}

model PrinterBrand {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  apiVersion  String    @default("v1")
  baseUrl     String    @default("https://open.spyun.net/v1")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  printers    Printer[]

  @@index([code])
  @@index([isActive])
}

model Printer {
  id            String        @id @default(cuid())
  storeId       String
  brandId       String
  name          String?
  serialNumber  String
  secretKey     String
  model         String?
  status        PrinterStatus @default(ACTIVE)
  printCopies   Int           @default(1)
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  brand         PrinterBrand  @relation(fields: [brandId], references: [id])

  @@unique([storeId, serialNumber])
  @@index([storeId])
  @@index([brandId])
  @@index([status])
}

// ============================================
// 夜狼业务流程配置模型
// ============================================

// 店铺类别级默认流程配置（StoreType 就是类别标识）
model StoreFlowConfig {
  id        String      @id @default(cuid())
  storeType StoreType
  name      String
  rules     Json        // [{ trigger, conditions, actions, timeout }]
  status    String      @default("ACTIVE")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  overrides StoreFlowOverride[]

  @@unique([storeType])
}

// 店铺级流程覆盖（个别店铺覆盖默认配置的部分规则）
model StoreFlowOverride {
  id        String   @id @default(cuid())
  storeId   String
  configId  String
  overrides Json     // 只存改动的规则，合并到默认配置上
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  config StoreFlowConfig @relation(fields: [configId], references: [id])

  @@unique([storeId])
  @@index([storeId])
}