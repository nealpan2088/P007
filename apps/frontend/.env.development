# 麒麟项目前端 - 开发环境配置
VITE_APP_NAME=快点餐扫码云打印餐管系统
VITE_APP_VERSION=0.1.0

# 开发环境：走 Vite proxy（/api → localhost:33038）
VITE_API_BASE_URL=
VITE_API_TIMEOUT=30000

VITE_FEATURE_AUTH=true
VITE_FEATURE_MULTI_TENANT=true
VITE_FEATURE_PRINTING=true
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_PAYMENT=true

VITE_DEFAULT_LANGUAGE=zh-CN
VITE_DEFAULT_CURRENCY=CNY
VITE_DEFAULT_TIMEZONE=Asia/Shanghai
VITE_SUPPORT_EMAIL=support@qilin-dining.com
VITE_SUPPORT_PHONE=400-888-8888
