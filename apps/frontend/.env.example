# 麒麟项目前端 - 环境配置模板
# 复制此文件为 .env 并填写实际值

# 环境设置
VITE_NODE_ENV=development
VITE_PORT=5177

# API配置
VITE_API_BASE_URL=http://localhost:33038
VITE_API_TIMEOUT=10000

# 认证配置
VITE_JWT_TOKEN_KEY=qilin_access_token
VITE_REFRESH_TOKEN_KEY=qilin_refresh_token
VITE_TOKEN_EXPIRY_CHECK_INTERVAL=60000  # 1分钟检查一次

# 功能开关
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_TOOLS=true
VITE_ENABLE_MOCK_API=true

# 路由配置
VITE_BASE_PATH=/
VITE_HASH_ROUTER=false

# 上传配置
VITE_MAX_FILE_SIZE=5242880  # 5MB
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# 打印机配置 (扫码点餐)
VITE_SHANGPENG_APP_ID=your-shangpeng-app-id
VITE_SHANGPENG_PRINTER_SN=your-printer-serial-number

# 开发工具
VITE_ENABLE_REACT_DEVTOOLS=true
VITE_ENABLE_REDUX_DEVTOOLS=true

# 性能配置
VITE_IMAGE_LAZY_LOADING=true
VITE_CODE_SPLITTING=true
VITE_PREFETCH_LINKS=true

# 主题配置
VITE_THEME=light  # light, dark, system
VITE_PRIMARY_COLOR=#1890ff
VITE_SECONDARY_COLOR=#52c41a

# 国际化
VITE_DEFAULT_LOCALE=zh-CN
VITE_FALLBACK_LOCALE=en-US
VITE_SUPPORTED_LOCALES=zh-CN,en-US