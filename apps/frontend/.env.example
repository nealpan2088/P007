# ============================================
# 麒麟项目前端 - 环境变量配置
# 所有配置通过环境变量管理，禁止硬编码
# ============================================

# ================= 应用信息 =================
VITE_APP_NAME=麒麟云点餐SaaS
VITE_APP_VERSION=0.1.0
VITE_APP_DESCRIPTION=多店铺扫码点餐云打印SaaS平台

# ================= API配置 =================
VITE_API_BASE_URL=http://localhost:33037
VITE_API_TIMEOUT=30000
VITE_API_VERSION=v1

# ================= 功能开关 =================
VITE_FEATURE_AUTH=true
VITE_FEATURE_MULTI_TENANT=true
VITE_FEATURE_PRINTING=true
VITE_FEATURE_ANALYTICS=true
VITE_FEATURE_PAYMENT=true

# ================= 第三方服务 =================
# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# Sentry错误监控
VITE_SENTRY_DSN=

# Stripe支付
VITE_STRIPE_PUBLIC_KEY=

# ================= 业务配置 =================
VITE_DEFAULT_LANGUAGE=zh-CN
VITE_DEFAULT_CURRENCY=CNY
VITE_DEFAULT_TIMEZONE=Asia/Shanghai
VITE_SUPPORT_EMAIL=support@qilin-dining.com
VITE_SUPPORT_PHONE=400-888-8888

# ================= 开发配置 =================
VITE_PORT=5177
VITE_HOST=localhost
VITE_API_PROXY_TARGET=http://localhost:33037
VITE_DEV_OPEN_BROWSER=true

# ============================================
# 环境变量使用说明：
# 
# 1. 开发环境 (.env.development):
#    - 复制此文件为 .env.development
#    - 修改配置为开发环境值
# 
# 2. 生产环境 (.env.production):
#    - 复制此文件为 .env.production  
#    - 修改配置为生产环境值
#    - 确保敏感信息安全
# 
# 3. 本地环境 (.env.local):
#    - 复制此文件为 .env.local
#    - 覆盖特定配置
#    - 不提交到版本控制
# 
# 重要原则：
# 1. 所有配置必须通过环境变量管理
# 2. 禁止在代码中硬编码任何配置
# 3. 敏感信息必须通过安全方式管理
# 4. 不同环境使用不同的配置文件
# ============================================