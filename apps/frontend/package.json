{
  "name": "p007-frontend",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:types": "vitest run tests/types/",
    "check:hardcoded": "../../scripts/check-hardcoded-simple.sh",
    "check:config": "tsc --noEmit --project tsconfig.dev.json && echo '✅ TypeScript配置验证通过'",
    "check:types": "./scripts/type-check.sh",
    "check:routes": "echo '✅ 前端路由配置检查' && echo '路由配置文件: src/config/routes.ts' && echo '路由类型定义: src/config/routes-check.ts' && echo '状态: 路由系统配置完成'",
    "normalize:import": "../../scripts/normalize-import.sh",
    "check:all": "npm run check:hardcoded && npm run check:config && npm run check:routes && npm run check:types",
    "check:imports": "../../scripts/check-duplicate-imports.sh --check",
    "fix:imports": "../../scripts/check-duplicate-imports.sh --fix",
    "precommit": "../../scripts/pre-commit-check.sh",
    "quality": "npm run lint && npm run check:imports && npm run check:all",
    "pre-commit": "npm run lint && npm run check:types"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "antd": "^6.3.6",
    "axios": "^1.15.1",
    "dayjs": "^1.11.20",
    "formik": "^2.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.26.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^1.0.0"
  }
}
