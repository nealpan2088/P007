    name: '麒麟科技',
    address: '上海市浦东新区',
    website: 'https://qilin-dining.com',
    copyright: `© ${new Date().getFullYear()} 麒麟科技 版权所有`,
  },
};

// API配置
export const apiConfig = {
  // 基础配置
  baseUrl: env.VITE_API_BASE_URL || `http://localhost:${import.meta.env.DEV ? '33037' : '80'}`,
  timeout: parseInt(env.VITE_API_TIMEOUT || '30000', 10),
  version: env.VITE_API_VERSION || 'v1',
  
  // 端点
  endpoints: {
    // 认证
    auth: {
      login: '/api/v1/auth/login',
      register: '/api/v1/auth/register',
      logout: '/api/v1/auth/logout',
      refresh: '/api/v1/auth/refresh-token',
      forgotPassword: '/api/v1/auth/forgot-password',
      resetPassword: '/api/v1/auth/reset-password',
    },
    
    // 租户
    tenant: {
      info: '/api/v1/tenant',
      update: '/api/v1/tenant',
      billing: '/api/v1/tenant/billing',
      subscription: '/api/v1/tenant/subscription',
    },
    
    // 店铺
    stores: {
      list: '/api/v1/stores',
      create: '/api/v1/stores',
      detail: '/api/v1/stores/:id',
      update: '/api/v1/stores/:id',
      delete: '/api/v1/stores/:id',
      stats: '/api/v1/stores/:id/stats',
    },
    
    // 菜单
    menu: {
      categories: '/api/v1/stores/:storeId/menu/categories',
      items: '/api/v1/stores/:storeId/menu/items',
    },
    
    // 订单
    orders: {
      list: '/api/v1/stores/:storeId/orders',
      create: '/api/v1/stores/:storeId/orders',
      detail: '/api/v1/stores/:storeId/orders/:orderId',
      update: '/api/v1/stores/:storeId/orders/:orderId',
      status: '/api/v1/stores/:storeId/orders/:orderId/status',
    },
    
    // 打印机
    printers: {
      list: '/api/v1/stores/:storeId/printers',
      test: '/api/v1/stores/:storeId/printers/:printerId/test',
    },
    
    // 统计分析
    analytics: {
      sales: '/api/v1/analytics/sales',
      orders: '/api/v1/analytics/orders',
      customers: '/api/v1/analytics/customers',
    },
  },
  
  // 请求配置
  request: {
    retryCount: 3,
    retryDelay: 1000,
    timeout: 30000,
    headers: {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
    },
  },
  
  // 响应处理
  response: {
    successCodes: [200, 201, 204],
    errorCodes: [400, 401, 403, 404, 422, 429, 500, 502, 503, 504],
  },
  
  // 工具函数
  utils: {
    // 构建完整URL
    buildUrl(endpoint: string, params: Record<string, string | number> = {}): string {
      let url = endpoint;
      
      // 替换路径参数
      Object.keys(params).forEach(key => {
        const paramKey = `:${key}`;
        if (url.includes(paramKey)) {
          url = url.replace(paramKey, encodeURIComponent(params[key].toString()));
        }
      });
      
      return `${apiConfig.baseUrl}${url}`;
    },
    
    // 构建查询字符串
    buildQueryString(params: Record<string, string | number | boolean> = {}): string {
      const queryParams = new URLSearchParams();
      
      Object.keys(params).forEach(key => {
        if (params[key] !== undefined && params[key] !== null) {
          queryParams.append(key, params[key].toString());
        }
      });
      
      const queryString = queryParams.toString();
      return queryString ? `?${queryString}` : '';
    },
    
    // 构建完整API URL
    buildApiUrl(
      endpoint: string, 
      pathParams: Record<string, string | number> = {},
      queryParams: Record<string, string | number | boolean> = {}
    ): string {
      const url = this.buildUrl(endpoint, pathParams);
      const queryString = this.buildQueryString(queryParams);
      
      return `${url}${queryString}`;
    },
  },
};

// 功能开关配置
export const featureConfig = {
  // 核心功能
  auth: env.VITE_FEATURE_AUTH === 'true',
  multiTenant: env.VITE_FEATURE_MULTI_TENANT === 'true',
  printing: env.VITE_FEATURE_PRINTING === 'true',
  analytics: env.VITE_FEATURE_ANALYTICS === 'true',
  payment: env.VITE_FEATURE_PAYMENT === 'true',
  
  // 高级功能
  features: {
    // 认证相关
    socialLogin: false,
    twoFactorAuth: false,
    sso: false,
    
    // 业务功能
    inventoryManagement: true,
    customerManagement: true,
    staffManagement: true,
    tableManagement: true,
    menuManagement: true,
    orderManagement: true,
    printerManagement: true,
    
    // 分析功能
    salesAnalytics: true,
    customerAnalytics: true,
    inventoryAnalytics: true,
    realtimeDashboard: true,
    
    // 集成功能
    wechatIntegration: false,
    alipayIntegration: false,
    meituanIntegration: false,
    elemeIntegration: false,
    
    // 管理功能
    multiStore: true,
    roleBasedAccess: true,
    auditLog: true,
    backupRestore: false,
  },
  
  // 检查功能是否可用
  isEnabled(featureName: string): boolean {
    const featurePath = featureName.split('.');
    let current: any = this.features;
    
    for (const part of featurePath) {
      if (current[part] === undefined) {
        return false;
      }
      current = current[part];
    }
    
    return current === true;
  },
  
  // 获取所有可用功能
  getAvailableFeatures(): string[] {
    const features: string[] = [];
    
    const traverse = (obj: any, prefix = '') => {
      Object.keys(obj).forEach(key => {
        const fullKey = prefix ? `${prefix}.${key}` : key;
        
        if (typeof obj[key] === 'boolean') {
          if (obj[key]) {
            features.push(fullKey);
          }
        } else if (typeof obj[key] === 'object') {
          traverse(obj[key], fullKey);
        }
      });
    };
    
    traverse(this.features);
    return features;
  },
};

