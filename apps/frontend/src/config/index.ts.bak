// 麒麟项目前端 - 统一配置管理系统
// 所有配置通过环境变量管理，禁止硬编码

// 环境变量类型定义
interface EnvConfig {
  // 应用信息
  VITE_APP_NAME: string;
  VITE_APP_VERSION: string;
  VITE_APP_DESCRIPTION: string;
  
  // API配置
  VITE_API_BASE_URL: string;
  VITE_API_TIMEOUT: string;
  VITE_API_VERSION: string;
  
  // 功能开关
  VITE_FEATURE_AUTH: string;
  VITE_FEATURE_MULTI_TENANT: string;
  VITE_FEATURE_PRINTING: string;
  VITE_FEATURE_ANALYTICS: string;
  VITE_FEATURE_PAYMENT: string;
  
  // 第三方服务
  VITE_GOOGLE_ANALYTICS_ID: string;
  VITE_SENTRY_DSN: string;
  VITE_STRIPE_PUBLIC_KEY: string;
  
  // 业务配置
  VITE_DEFAULT_LANGUAGE: string;
  VITE_DEFAULT_CURRENCY: string;
  VITE_DEFAULT_TIMEZONE: string;
  VITE_SUPPORT_EMAIL: string;
  VITE_SUPPORT_PHONE: string;
  
  // 开发配置
  VITE_DEV_PROXY_TARGET: string;
  VITE_DEV_OPEN_BROWSER: string;
}

// 从环境变量加载配置
const env = import.meta.env as unknown as EnvConfig;

// 验证必需的环境变量
const requiredEnvVars = [
  'VITE_APP_NAME',
  'VITE_API_BASE_URL',
];

for (const envVar of requiredEnvVars) {
  if (!env[envVar as keyof EnvConfig]) {
    throw new Error(`❌ 必需的环境变量缺失: ${envVar}`);
  }
}

