export const routeConfig = {
  // 公共路由
  public: {
    home: '/',
    login: '/auth/login',
    register: '/auth/register',
    forgotPassword: '/auth/forgot-password',
    resetPassword: '/auth/reset-password/:token',
    pricing: '/pricing',
    features: '/features',
    about: '/about',
    contact: '/contact',
    privacy: '/privacy',
    terms: '/terms',
  },
  
  // 租户路由
  tenant: {
    dashboard: '/dashboard',
    stores: {
      list: '/stores',
      create: '/stores/create',
      detail: '/stores/:id',
      edit: '/stores/:id/edit',
      settings: '/stores/:id/settings',
    },
    menu: {
      categories: '/stores/:storeId/menu/categories',
      items: '/stores/:storeId/menu/items',
      itemDetail: '/stores/:storeId/menu/items/:itemId',
    },
    tables: {
      list: '/stores/:storeId/tables',
      create: '/stores/:storeId/tables/create',
      edit: '/stores/:storeId/tables/:id/edit',
    },
    orders: {
      list: '/stores/:storeId/orders',
      detail: '/stores/:storeId/orders/:orderId',
    },
    printers: {
      list: '/stores/:storeId/printers',
      create: '/stores/:storeId/printers/create',
      edit: '/stores/:storeId/printers/:id/edit',
      test: '/stores/:storeId/printers/:id/test',
    },
    analytics: {
      dashboard: '/analytics',
      sales: '/analytics/sales',
      orders: '/analytics/orders',
      customers: '/analytics/customers',
      inventory: '/analytics/inventory',
    },
    settings: {
      profile: '/settings/profile',
      account: '/settings/account',
      notifications: '/settings/notifications',
      security: '/settings/security',
      billing: '/settings/billing',
      integrations: '/settings/integrations',
    },
  },
  
  // 顾客路由
  customer: {
    scan: '/scan/:tableId',
    menu: '/table/:tableId/menu',
    cart: '/table/:tableId/cart',
    checkout: '/table/:tableId/checkout',
    orderSuccess: '/order/:orderId/success',
    orderStatus: '/order/:orderId/status',
  },
  
  // 工具函数
  utils: {
    // 构建路由URL
    buildRoute(route: string, params: Record<string, string | number> = {}): string {
      let url = route;
      
      Object.keys(params).forEach(key => {
        const paramKey = `:${key}`;
        if (url.includes(paramKey)) {
          url = url.replace(paramKey, encodeURIComponent(params[key].toString()));
        }
      });
      
      return url;
    },
    
    // 获取当前路由类别
    getRouteCategory(path: string): 'public' | 'tenant' | 'customer' | 'unknown' {
      if (path.startsWith('/auth/') || path === '/' || path.startsWith('/pricing')) {
        return 'public';
      } else if (path.startsWith('/dashboard') || path.startsWith('/stores') || path.startsWith('/settings')) {
        return 'tenant';
      } else if (path.startsWith('/scan') || path.startsWith('/table') || path.startsWith('/order')) {
        return 'customer';
      }
      return 'unknown';
    },
  },
};

// 导出所有配置
export default {
  app: appConfig,
  api: apiConfig,
  feature: featureConfig,
  business: businessConfig,
  thirdParty: thirdPartyConfig,
  dev: devConfig,
  route: routeConfig,
  
  // 工具函数
  getFullConfig() {
    return {
      app: appConfig,
      api: apiConfig,
      feature: featureConfig,
      business: businessConfig,
      thirdParty: thirdPartyConfig,
      dev: devConfig,
      route: routeConfig,
    };
  },
  
  // 验证配置
  validate(): boolean {
    const errors: string[] = [];
    
    // 验证API基础URL
    if (!apiConfig.baseUrl.startsWith('http')) {
      errors.push('API基础URL必须以http或https开头');
    }
    
    // 验证功能开关
    if (!featureConfig.auth) {
      errors.push('认证功能必须启用');
    }
    
    if (errors.length > 0) {
      console.error('配置验证失败:', errors);
      return false;
    }
    
    return true;
  },
  
  // 获取环境信息
  getEnvInfo() {
    return {
      mode: import.meta.env.MODE,
      prod: import.meta.env.PROD,
      dev: import.meta.env.DEV,
      ssr: import.meta.env.SSR,
      baseUrl: import.meta.env.BASE_URL,
    };
  },
  
  // 获取配置摘要（用于调试）
  getConfigSummary() {
    return {
      app: {
        name: appConfig.name,
        version: appConfig.version,
      },
      api: {
        baseUrl: apiConfig.baseUrl,
        timeout: apiConfig.timeout,
      },
      features: {
        enabled: featureConfig.getAvailableFeatures().length,
        list: featureConfig.getAvailableFeatures(),
      },
      business: {
        language: businessConfig.localization.defaultLanguage,
        currency: businessConfig.localization.defaultCurrency,
      },
      env: this.getEnvInfo(),
    };
  },
};