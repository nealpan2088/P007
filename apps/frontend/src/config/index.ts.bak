    description: env.VITE_APP_DESCRIPTION || '多店铺扫码点餐云打印SaaS平台',
    keywords: '扫码点餐,SaaS,云打印,餐厅管理,多店铺',
    author: '麒麟项目团队',
    ogImage: '/og-image.png',
    twitterCard: 'summary_large_image',
  },
  
  // 支持信息
  support: {
    email: env.VITE_SUPPORT_EMAIL || 'support@qilin-dining.com',
    phone: env.VITE_SUPPORT_PHONE || '400-888-8888',
    workingHours: '09:00-18:00 (周一至周五)',
